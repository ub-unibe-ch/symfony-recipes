{
    "manifests": {
        "ub-unibe-ch/dspace-api-bundle": {
            "manifest": {
                "bundles": {
                    "UB\\DspaceApiBundle\\UBDspaceApiBundle": [
                        "all"
                    ]
                },
                "env": {
                    "DSPACE_URL": "https://boris...unibe.ch",
                    "DSPACE_USER": "user",
                    "DSPACE_PASSWORD": "password"
                },
                "copy-from-recipe": {
                    "config/": "%CONFIG_DIR%/"
                }
            },
            "files": {
                "config/packages/ub_dspace_api.yaml": {
                    "contents": [
                        "ub_dspace_api:",
                        "    base_uri: '%env(DSPACE_URL)%'",
                        "    user: '%env(DSPACE_USER)%'",
                        "    password: '%env(DSPACE_PASSWORD)%'",
                        ""
                    ],
                    "executable": false
                }
            },
            "ref": "6f7e335473a67ba480e9e97c9a1705c79a1c8b61"
        }
    }
}
