{
    "manifests": {
        "ub-unibe-ch/translatable-entities-bundle": {
            "manifest": {
                "bundles": {
                    "UB\\TranslatableEntitiesBundle\\UBTranslatableEntitiesBundle": [
                        "all"
                    ]
                },
                "env": {
                    "UB_DEFAULT_LOCALE": "en",
                    "UB_AVAILABLE_LOCALES": "de,en",
                    "UB_FALLBACK_LOCALES": ""
                },
                "copy-from-recipe": {
                    "config/": "%CONFIG_DIR%/"
                }
            },
            "files": {
                "config/packages/ub_translatable_entities.yaml": {
                    "contents": [
                        "ub_translatable_entities:",
                        "    default_locale: '%env(UB_DEFAULT_LOCALE)%'",
                        "    available_locales: '%env(csv:UB_AVAILABLE_LOCALES)%'",
                        "    fallback_locales: '%env(csv:UB_FALLBACK_LOCALES)%'",
                        ""
                    ],
                    "executable": false
                }
            },
            "ref": "0d20279473604ca3c825279de4671c033a4f5230"
        }
    }
}
