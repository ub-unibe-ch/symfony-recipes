{
    "bundles": {
        "UB\\JobReportBundle\\UBJobReportBundle": ["all"]
    },
    "env": {
        "UB_JOB_REPORT_APP_NAME": "MyApp",
        "UB_JOB_REPORT_EMAIL_FROM": "noreply@example.com",
